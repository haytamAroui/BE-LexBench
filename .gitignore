# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Evaluation data — NEVER commit items, gold answers, or result sets ───────

# Block all JSONL anywhere (item banks, run outputs, held-out splits)
*.jsonl
!data/sample/sample.jsonl

# Block all JSON except the public item schema, synthetic sample, and release config
*.json
!schema/eval_item.schema.json
!data/sample/*.json
!release-please-config.json
!.release-please-manifest.json

# Block all of data/ except the public synthetic sample directory
/data/*
!/data/sample/

# Block run results
/results/

# Pytest base temp directory
/tmp_test/

